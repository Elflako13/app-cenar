<div class="d-flex align-items-center justify-content-between mb-4">
  <h4 class="fw-bold mb-0"><i class="bi bi-trash text-danger"></i> Eliminar Producto</h4>
  <a href="/commerce/products" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left"></i> Volver
  </a>
</div>

<div class="row justify-content-center">
  <div class="col-lg-5">
    <div class="card border-0 shadow-sm" style="border-top: 4px solid #dc3545 !important;">
      <div class="card-body p-4 text-center">
        {{#if product.image}}
          <img src="{{product.image}}" alt="{{product.name}}" class="rounded mb-3" style="width:80px;height:80px;object-fit:cover;">
        {{else}}
          <i class="bi bi-exclamation-triangle display-4 text-danger mb-3"></i>
        {{/if}}
        <h5 class="fw-bold">¿Eliminar este producto?</h5>
        <p class="text-muted mb-1">Estás a punto de eliminar el producto:</p>
        <p class="fw-semibold fs-5 mb-1">"{{product.name}}"</p>
        <p class="text-danger fw-bold mb-3">RD$ {{product.price}}</p>
        <p class="text-muted small">Esta acción no se puede deshacer.</p>

        <div class="d-flex gap-2 justify-content-center mt-4">
          <a href="/commerce/products" class="btn btn-outline-secondary">
            <i class="bi bi-x-circle"></i> Cancelar
          </a>
          <form action="/commerce/products/{{product._id}}/delete" method="POST" class="d-inline">
            <button type="submit" class="btn btn-danger">
              <i class="bi bi-trash"></i> Sí, Eliminar
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
