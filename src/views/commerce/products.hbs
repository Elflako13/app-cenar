<div class="d-flex align-items-center justify-content-between mb-4">
  <h4 class="fw-bold mb-0"><i class="bi bi-box-seam text-danger"></i> Productos</h4>
  <a href="/commerce/products/create" class="btn btn-danger btn-sm">
    <i class="bi bi-plus-circle"></i> Nuevo Producto
  </a>
</div>

{{#if products.length}}
  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Imagen</th>
              <th>Nombre</th>
              <th>Categoría</th>
              <th>Descripción</th>
              <th class="text-end">Precio</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#each products}}
              <tr>
                <td>
                  {{#if image}}
                    <img src="{{image}}" alt="{{name}}" class="rounded" style="width:48px;height:48px;object-fit:cover;">
                  {{else}}
                    <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                      <i class="bi bi-image text-muted"></i>
                    </div>
                  {{/if}}
                </td>
                <td class="fw-semibold">{{name}}</td>
                <td><span class="badge bg-secondary">{{category.name}}</span></td>
                <td class="text-muted small">{{description}}</td>
                <td class="text-end fw-bold text-danger">RD$ {{price}}</td>
                <td class="text-end">
                  <a href="/commerce/products/{{_id}}/edit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil"></i>
                  </a>
                  <a href="/commerce/products/{{_id}}/delete" class="btn btn-sm btn-outline-danger ms-1">
                    <i class="bi bi-trash"></i>
                  </a>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
{{else}}
  <div class="text-center py-5">
    <i class="bi bi-box-seam display-1 text-muted"></i>
    <p class="mt-3 text-muted">No tienes productos creados aún.</p>
    <a href="/commerce/products/create" class="btn btn-danger mt-2">
      <i class="bi bi-plus-circle"></i> Crear primer producto
    </a>
  </div>
{{/if}}
