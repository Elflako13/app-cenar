<div class="d-flex align-items-center justify-content-between mb-4">
  <h4 class="fw-bold mb-0"><i class="bi bi-trash text-danger"></i> Eliminar Categoría</h4>
  <a href="/commerce/categories" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left"></i> Volver
  </a>
</div>

<div class="row justify-content-center">
  <div class="col-lg-5">
    <div class="card border-0 shadow-sm border-danger" style="border-top: 4px solid #dc3545 !important;">
      <div class="card-body p-4 text-center">
        <i class="bi bi-exclamation-triangle display-4 text-danger mb-3"></i>
        <h5 class="fw-bold">¿Eliminar esta categoría?</h5>
        <p class="text-muted mb-1">Estás a punto de eliminar la categoría:</p>
        <p class="fw-semibold fs-5 mb-3">"{{category.name}}"</p>
        <p class="text-muted small">Esta acción no se puede deshacer.</p>

        <div class="d-flex gap-2 justify-content-center mt-4">
          <a href="/commerce/categories" class="btn btn-outline-secondary">
            <i class="bi bi-x-circle"></i> Cancelar
          </a>
          <form action="/commerce/categories/{{category._id}}/delete" method="POST" class="d-inline">
            <button type="submit" class="btn btn-danger">
              <i class="bi bi-trash"></i> Sí, Eliminar
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
