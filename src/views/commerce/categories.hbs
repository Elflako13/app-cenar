<div class="d-flex align-items-center justify-content-between mb-4">
  <h4 class="fw-bold mb-0"><i class="bi bi-tags text-danger"></i> Categorías</h4>
  <a href="/commerce/categories/create" class="btn btn-danger btn-sm">
    <i class="bi bi-plus-circle"></i> Nueva Categoría
  </a>
</div>

{{#if categories.length}}
  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Nombre</th>
              <th>Descripción</th>
              <th class="text-center">Productos</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#each categories}}
              <tr>
                <td class="fw-semibold">{{name}}</td>
                <td class="text-muted">{{description}}</td>
                <td class="text-center"><span class="badge bg-secondary">{{productCount}}</span></td>
                <td class="text-end">
                  <a href="/commerce/categories/{{_id}}/edit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil"></i>
                  </a>
                  <a href="/commerce/categories/{{_id}}/delete" class="btn btn-sm btn-outline-danger ms-1">
                    <i class="bi bi-trash"></i>
                  </a>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
{{else}}
  <div class="text-center py-5">
    <i class="bi bi-tags display-1 text-muted"></i>
    <p class="mt-3 text-muted">No tienes categorías creadas aún.</p>
    <a href="/commerce/categories/create" class="btn btn-danger mt-2">
      <i class="bi bi-plus-circle"></i> Crear primera categoría
    </a>
  </div>
{{/if}}
