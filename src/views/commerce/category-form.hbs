<div class="d-flex align-items-center justify-content-between mb-4">
  <h4 class="fw-bold mb-0">
    <i class="bi bi-{{#if isEdit}}pencil{{else}}plus-circle{{/if}} text-danger"></i>
    {{#if isEdit}}Editar Categoría{{else}}Nueva Categoría{{/if}}
  </h4>
  <a href="/commerce/categories" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left"></i> Volver
  </a>
</div>

<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <form action="/commerce/categories/{{#if isEdit}}{{category._id}}/edit{{else}}create{{/if}}" method="POST">
          <div class="mb-3">
            <label class="form-label fw-semibold">Nombre <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control" value="{{category.name}}" placeholder="Nombre de la categoría" required>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold">Descripción</label>
            <textarea name="description" class="form-control" rows="3" placeholder="Descripción opcional">{{category.description}}</textarea>
          </div>

          <div class="d-flex gap-2 justify-content-end">
            <a href="/commerce/categories" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-danger">
              <i class="bi bi-save"></i> {{#if isEdit}}Actualizar{{else}}Crear{{/if}}
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
