<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow">
      <div class="card-body p-4">
        <h5>{{#if isEdit}}Editar{{else}}Nuevo{{/if}} Tipo de Comercio</h5>
        <form method="POST" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input type="text" name="name" class="form-control" value="{{formData.name}}" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Icono{{#if isEdit}} (dejar vacío para mantener el actual){{/if}}</label>
            {{#if isEdit}}{{#if formData.icon}}<img src="{{formData.icon}}" width="60" class="mb-2 d-block">{{/if}}{{/if}}
            <input type="file" name="icon" class="form-control" accept="image/*">
          </div>
          <div class="d-flex gap-2">
            <a href="/admin/commerce-types" class="btn btn-secondary">Volver</a>
            <button type="submit" class="btn btn-danger">{{#if isEdit}}Guardar{{else}}Crear{{/if}}</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
