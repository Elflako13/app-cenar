<div class="d-flex justify-content-between align-items-center mb-3">
  <h4>Listado de Clientes</h4>
</div>
<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
      <tr><th>Nombre</th><th>Apellido</th><th>Correo</th><th>Teléfono</th><th>Pedidos</th><th>Estado</th><th>Acción</th></tr>
    </thead>
    <tbody>
      {{#each clients}}
      <tr>
        <td>{{firstName}}</td>
        <td>{{lastName}}</td>
        <td>{{email}}</td>
        <td>{{phone}}</td>
        <td>{{orderCount}}</td>
        <td><span class="badge bg-{{#if isActive}}success{{else}}secondary{{/if}}">{{#if isActive}}Activo{{else}}Inactivo{{/if}}</span></td>
        <td>
          <form method="POST" action="/admin/users/{{_id}}/toggle-status" class="d-inline">
            <button class="btn btn-sm btn-{{#if isActive}}warning{{else}}success{{/if}}">
              {{#if isActive}}Inactivar{{else}}Activar{{/if}}
            </button>
          </form>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
