<h4 class="mb-4">Dashboard</h4>
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="card text-bg-primary text-center p-3">
      <div class="fs-1 fw-bold">{{stats.totalOrders}}</div>
      <div>Pedidos Totales</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-bg-info text-center p-3">
      <div class="fs-1 fw-bold">{{stats.todayOrders}}</div>
      <div>Pedidos Hoy</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-bg-success text-center p-3">
      <div class="fs-1 fw-bold">{{stats.activeCommerces}}</div>
      <div>Comercios Activos</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-bg-secondary text-center p-3">
      <div class="fs-1 fw-bold">{{stats.inactiveCommerces}}</div>
      <div>Comercios Inactivos</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-bg-success text-center p-3">
      <div class="fs-1 fw-bold">{{stats.activeClients}}</div>
      <div>Clientes Activos</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-bg-secondary text-center p-3">
      <div class="fs-1 fw-bold">{{stats.inactiveClients}}</div>
      <div>Clientes Inactivos</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-bg-success text-center p-3">
      <div class="fs-1 fw-bold">{{stats.activeDeliveries}}</div>
      <div>Deliveries Activos</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-bg-warning text-center p-3">
      <div class="fs-1 fw-bold">{{stats.totalProducts}}</div>
      <div>Productos</div>
    </div>
  </div>
</div>
