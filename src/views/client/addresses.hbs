<div class="d-flex align-items-center justify-content-between mb-4">
  <div class="d-flex align-items-center gap-2">
    <a href="/client" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-arrow-left"></i> Volver
    </a>
    <h4 class="mb-0 ms-2 fw-bold"><i class="bi bi-geo-alt text-danger"></i> Mis Direcciones</h4>
  </div>
  <a href="/client/addresses/create" class="btn btn-danger btn-sm">
    <i class="bi bi-plus-lg"></i> Nueva Dirección
  </a>
</div>

{{#if addresses.length}}
  <div class="row g-3">
    {{#each addresses}}
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm border-0">
          <div class="card-body">
            <h6 class="card-title fw-bold mb-1">
              <i class="bi bi-bookmark-fill text-danger"></i> {{label}}
            </h6>
            <p class="card-text text-muted small mb-1">
              <i class="bi bi-signpost"></i> {{street}}
            </p>
            <p class="card-text text-muted small mb-1">
              <i class="bi bi-map"></i> {{sector}}, {{city}}
            </p>
            {{#if reference}}
              <p class="card-text text-muted small mb-0">
                <i class="bi bi-info-circle"></i> {{reference}}
              </p>
            {{/if}}
          </div>
          <div class="card-footer bg-white border-top-0 d-flex gap-2">
            <a href="/client/addresses/{{_id}}/edit" class="btn btn-outline-primary btn-sm flex-grow-1">
              <i class="bi bi-pencil"></i> Editar
            </a>
            <a href="/client/addresses/{{_id}}/delete" class="btn btn-outline-danger btn-sm flex-grow-1">
              <i class="bi bi-trash3"></i> Eliminar
            </a>
          </div>
        </div>
      </div>
    {{/each}}
  </div>
{{else}}
  <div class="text-center py-5">
    <i class="bi bi-geo-alt display-1 text-muted"></i>
    <p class="mt-3 text-muted">No tienes direcciones registradas.</p>
    <a href="/client/addresses/create" class="btn btn-danger mt-2">
      <i class="bi bi-plus-lg"></i> Agregar dirección
    </a>
  </div>
{{/if}}
