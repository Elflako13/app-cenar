<div class="row mb-4">
  <div class="col">
    <h2 class="fw-bold">¿Qué quieres pedir hoy?</h2>
    <p class="text-muted">Selecciona una categoría de comercio para comenzar</p>
  </div>
</div>

{{#if commerceTypes.length}}
  <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-4">
    {{#each commerceTypes}}
      <div class="col">
        <a href="/client/commerces?typeId={{_id}}" class="text-decoration-none">
          <div class="card h-100 text-center shadow-sm border-0 commerce-type-card">
            <div class="card-body d-flex flex-column align-items-center justify-content-center py-4">
              {{#if icon}}
                <img src="{{icon}}" alt="{{name}}" class="mb-3 rounded" style="width:64px;height:64px;object-fit:cover;">
              {{else}}
                <div class="rounded-circle bg-danger bg-opacity-10 d-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;">
                  <i class="bi bi-shop text-danger fs-3"></i>
                </div>
              {{/if}}
              <h6 class="card-title mb-0 fw-semibold text-dark">{{name}}</h6>
            </div>
          </div>
        </a>
      </div>
    {{/each}}
  </div>
{{else}}
  <div class="text-center py-5">
    <i class="bi bi-shop display-1 text-muted"></i>
    <p class="mt-3 text-muted">No hay categorías disponibles por el momento.</p>
  </div>
{{/if}}

<style>
  .commerce-type-card {
    transition: transform 0.2s, box-shadow 0.2s;
    cursor: pointer;
  }
  .commerce-type-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12) !important;
  }
</style>
