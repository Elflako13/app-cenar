<div class="row justify-content-center">
  <div class="col-md-7 col-lg-6">
    <div class="d-flex align-items-center mb-4 gap-2">
      <a href="/client/addresses" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Volver
      </a>
      <h4 class="mb-0 ms-2 fw-bold">
        {{#if isEdit}}Editar Dirección{{else}}Nueva Dirección{{/if}}
      </h4>
    </div>

    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <form method="POST"
          action="{{#if isEdit}}/client/addresses/{{address._id}}/edit{{else}}/client/addresses/create{{/if}}">

          <div class="mb-3">
            <label for="label" class="form-label fw-semibold">Etiqueta <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="label" name="label"
              placeholder="Ej: Casa, Trabajo, Oficina…"
              value="{{address.label}}" required>
            <div class="form-text">Un nombre corto para identificar esta dirección.</div>
          </div>

          <div class="mb-3">
            <label for="street" class="form-label fw-semibold">Calle / Dirección <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="street" name="street"
              placeholder="Ej: Calle Principal #15"
              value="{{address.street}}" required>
          </div>

          <div class="mb-3">
            <label for="sector" class="form-label fw-semibold">Sector <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="sector" name="sector"
              placeholder="Ej: Piantini"
              value="{{address.sector}}" required>
          </div>

          <div class="mb-3">
            <label for="city" class="form-label fw-semibold">Ciudad <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="city" name="city"
              placeholder="Ej: Santo Domingo"
              value="{{address.city}}" required>
          </div>

          <div class="mb-4">
            <label for="reference" class="form-label fw-semibold">Referencia</label>
            <input type="text" class="form-control" id="reference" name="reference"
              placeholder="Ej: Frente al parque, edificio azul…"
              value="{{address.reference}}">
            <div class="form-text">Opcional. Ayuda al delivery a encontrarte más fácil.</div>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger flex-grow-1">
              <i class="bi bi-floppy"></i>
              {{#if isEdit}}Guardar cambios{{else}}Crear dirección{{/if}}
            </button>
            <a href="/client/addresses" class="btn btn-outline-secondary">
              <i class="bi bi-x-lg"></i> Cancelar
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
