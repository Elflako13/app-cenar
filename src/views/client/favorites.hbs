<div class="d-flex align-items-center justify-content-between mb-4">
  <div class="d-flex align-items-center gap-2">
    <a href="/client" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-arrow-left"></i> Volver
    </a>
    <h4 class="mb-0 ms-2 fw-bold"><i class="bi bi-heart-fill text-danger"></i> Mis Favoritos</h4>
  </div>
</div>

{{#if favorites.length}}
  <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
    {{#each favorites}}
      <div class="col">
        <div class="card h-100 shadow-sm border-0">
          <a href="/client/commerce/{{commerce._id}}/catalog" class="text-decoration-none text-dark">
            {{#if commerce.logo}}
              <img src="{{commerce.logo}}" class="card-img-top" alt="{{commerce.name}}" style="height:150px;object-fit:cover;">
            {{else}}
              <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height:150px;">
                <i class="bi bi-shop text-muted display-4"></i>
              </div>
            {{/if}}
            <div class="card-body pb-1">
              <h6 class="card-title fw-semibold mb-1">{{commerce.name}}</h6>
              {{#if commerce.commerceType.name}}
                <small class="text-muted">
                  <i class="bi bi-tag"></i> {{commerce.commerceType.name}}
                </small>
              {{/if}}
              {{#if commerce.description}}
                <p class="card-text text-muted small mt-1 mb-0">{{commerce.description}}</p>
              {{/if}}
            </div>
          </a>
          <div class="card-footer bg-white border-top-0">
            <form method="POST" action="/client/favorites/remove">
              <input type="hidden" name="commerceId" value="{{commerce._id}}">
              <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                <i class="bi bi-heart-fill"></i> Quitar de favoritos
              </button>
            </form>
          </div>
        </div>
      </div>
    {{/each}}
  </div>
{{else}}
  <div class="text-center py-5">
    <i class="bi bi-heart display-1 text-muted"></i>
    <p class="mt-3 text-muted">No tienes comercios guardados en favoritos.</p>
    <a href="/client" class="btn btn-danger mt-2">
      <i class="bi bi-shop"></i> Explorar comercios
    </a>
  </div>
{{/if}}
