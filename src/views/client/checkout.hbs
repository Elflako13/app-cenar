<div class="d-flex align-items-center mb-4 gap-2">
  <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left"></i> Volver al catálogo
  </a>
  <h4 class="mb-0 ms-2 fw-bold">Confirmar Pedido</h4>
</div>

<form method="POST" action="/client/orders" id="checkout-form">
  <input type="hidden" name="commerceId" value="{{commerce._id}}">
  <input type="hidden" name="items" value="{{items}}">

  <div class="row g-4">
    {{!-- LEFT: Address selection --}}
    <div class="col-lg-7">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-white fw-bold border-bottom">
          <i class="bi bi-geo-alt text-danger"></i> Dirección de entrega
        </div>
        <div class="card-body">
          {{#if addresses.length}}
            {{#each addresses}}
              <div class="form-check mb-3 p-3 border rounded {{#if @first}}border-danger{{/if}}">
                <input class="form-check-input" type="radio" name="addressId"
                  id="addr-{{_id}}" value="{{_id}}"
                  {{#if @first}}checked{{/if}} required>
                <label class="form-check-label w-100" for="addr-{{_id}}">
                  <span class="fw-semibold">{{label}}</span><br>
                  <small class="text-muted">
                    {{street}}, {{sector}}, {{city}}
                    {{#if reference}} — {{reference}}{{/if}}
                  </small>
                </label>
              </div>
            {{/each}}
          {{else}}
            <div class="alert alert-warning mb-0">
              <i class="bi bi-exclamation-triangle"></i>
              No tienes direcciones registradas.
              <a href="/client/addresses/create" class="alert-link">Agregar dirección</a>
            </div>
          {{/if}}

          <a href="/client/addresses/create" class="btn btn-outline-secondary btn-sm mt-2">
            <i class="bi bi-plus-lg"></i> Nueva dirección
          </a>
        </div>
      </div>
    </div>

    {{!-- RIGHT: Order summary --}}
    <div class="col-lg-5">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-danger text-white fw-bold">
          <i class="bi bi-receipt"></i> Resumen del pedido
        </div>
        <div class="card-body">
          {{!-- Commerce info --}}
          <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom">
            {{#if commerce.logo}}
              <img src="{{commerce.logo}}" alt="{{commerce.name}}" class="rounded" style="width:52px;height:52px;object-fit:cover;">
            {{else}}
              <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width:52px;height:52px;">
                <i class="bi bi-shop text-muted fs-4"></i>
              </div>
            {{/if}}
            <div>
              <div class="fw-semibold">{{commerce.name}}</div>
              <small class="text-muted">{{commerce.phone}}</small>
            </div>
          </div>

          {{!-- Totals --}}
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Subtotal</span>
            <span>RD$ {{subtotal}}</span>
          </div>
          <div class="d-flex justify-content-between mb-2 text-muted">
            <span>ITBIS ({{itbisPercentage}}%)</span>
            <span>RD$ {{itbisAmount}}</span>
          </div>
          <hr>
          <div class="d-flex justify-content-between fw-bold fs-5">
            <span>Total</span>
            <span class="text-danger">RD$ {{total}}</span>
          </div>
        </div>
        <div class="card-footer bg-white border-top-0">
          {{#if addresses.length}}
            <button type="submit" class="btn btn-danger w-100 fw-semibold">
              <i class="bi bi-bag-check-fill"></i> Pedir ahora
            </button>
          {{else}}
            <button type="button" class="btn btn-secondary w-100" disabled>
              <i class="bi bi-bag-check-fill"></i> Pedir ahora
            </button>
            <small class="text-muted d-block text-center mt-1">Agrega una dirección para continuar</small>
          {{/if}}
        </div>
      </div>
    </div>
  </div>
</form>

<script>
  // Highlight selected address card
  document.querySelectorAll('input[name="addressId"]').forEach(radio => {
    radio.addEventListener('change', function() {
      document.querySelectorAll('.form-check').forEach(el => el.classList.remove('border-danger'));
      if (this.checked) this.closest('.form-check').classList.add('border-danger');
    });
  });
</script>
