<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow">
      <div class="card-body p-4">
        <h3 class="text-center mb-4"><i class="bi bi-cup-hot-fill text-danger"></i> AppCenar</h3>
        <h5 class="text-center mb-3">Iniciar Sesión</h5>

        <form action="/login" method="POST">
          <div class="mb-3">
            <label class="form-label">Usuario o Correo</label>
            <input type="text" name="userNameOrEmail" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Contraseña</label>
            <input type="password" name="password" class="form-control" required>
          </div>
          <button type="submit" class="btn btn-danger w-100">Iniciar Sesión</button>
        </form>

        <hr>
        <div class="d-grid gap-2">
          <a href="/register" class="btn btn-outline-secondary btn-sm">Registrarse como Cliente o Delivery</a>
          <a href="/register-commerce" class="btn btn-outline-secondary btn-sm">Registrarse como Comercio</a>
          <a href="/forgot-password" class="btn btn-link btn-sm text-center">¿Olvidaste tu contraseña?</a>
        </div>
      </div>
    </div>
  </div>
</div>
