<div class="row justify-content-center">
  <div class="col-md-4">
    <div class="card shadow">
      <div class="card-body p-4">
        <h5 class="mb-3">Restablecer Contraseña</h5>
        <form action="/forgot-password" method="POST">
          <div class="mb-3">
            <label class="form-label">Usuario o Correo</label>
            <input type="text" name="userNameOrEmail" class="form-control" required>
          </div>
          <button type="submit" class="btn btn-danger w-100">Enviar enlace</button>
        </form>
        <a href="/login" class="btn btn-link w-100 mt-2">Volver al login</a>
      </div>
    </div>
  </div>
</div>
